# Production secrets for docker compose (used on the droplet).
# Copy to ".env" on the server and fill in strong values — DO NOT commit ".env".
#
# Generate strong values:
#   AUTH_SECRET:                 openssl rand -base64 48
#   ADMIN_PASSWORD / DB_*PASSWORD: openssl rand -base64 18
#
# Compose reads this automatically from the project directory. If a variable is
# left unset, docker-compose.yml falls back to weak DEV defaults (fine locally,
# NOT for production) — always set all of these on the droplet.

# MySQL root password (admin access to the DB server)
DB_ROOT_PASSWORD=

# Password for the application DB user "nissan"
DB_PASSWORD=

# Admin control-panel login (/admin)
ADMIN_USER=admin
ADMIN_PASSWORD=

# Secret used to sign admin session cookies (HMAC key)
AUTH_SECRET=
